 Kubernetes Deployment

15.1 Create Workflow Folder

Inside project:

.github
   |
   └── workflows
          |
          └── ci-cd.yml
15.2 Build Pipeline

Example:

name: Microservice CI/CD


on:
  push:
    branches:
      - main


jobs:

 build:

  runs-on: ubuntu-latest


  steps:

  - name: Checkout Code
    uses: actions/checkout@v4


  - name: Node Setup
    uses: actions/setup-node@v4
    with:
      node-version: 22


  - name: Install Dependencies
    run: |
      cd auth-service
      npm install


  - name: Docker Build
    run: |
      docker build \
      -t auth-service:v1 \
      ./auth-service

